generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  series       Series[]
}

model Series {
  id             String        @id @default(cuid())
  userId         String
  title          String
  description    String?
  visualStyle    String
  tone           String
  defaultFormat  String        @default("9:16")
  coverImageUrl  String?
  createdAt      DateTime      @default(now())
  user          User          @relation(fields: [userId], references: [id])
  characters    Character[]
  environments  Environment[]
  episodes      Episode[]
  assets        Asset[]
}

model Character {
  id                  String   @id @default(cuid())
  seriesId            String
  name                String
  physicalDescription String
  outfit              String
  personality         String
  voiceProfile        String?
  heygenVoiceId       String?
  referenceImageUrl   String?
  consistencyPrompt   String
  visualDNA           String?
  createdAt           DateTime @default(now())
  series              Series   @relation(fields: [seriesId], references: [id], onDelete: Cascade)
}

model Environment {
  id              String   @id @default(cuid())
  seriesId        String
  name            String
  description     String
  lighting        String?
  mood            String?
  reusable        Boolean  @default(true)
  previewImageUrl String?
  createdAt       DateTime @default(now())
  series          Series   @relation(fields: [seriesId], references: [id], onDelete: Cascade)
}

model Episode {
  id        String   @id @default(cuid())
  seriesId  String
  title     String
  duration  Int?
  format    String   @default("9:16")
  status    String   @default("draft")
  script    String?
  createdAt DateTime @default(now())
  series    Series   @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  scenes    Scene[]
}

model Scene {
  id              String         @id @default(cuid())
  episodeId       String
  sceneNumber     Int
  timecode        String?
  location        String?
  charactersJson  String?
  action          String?
  narration       String?
  dialogue        String?
  camera          String?
  emotion         String?
  soundDesign     String?
  imagePrompt     String?
  videoPrompt     String?
  imageUrl        String?
  imageHistory    String?
  videoUrl        String?
  qualityScore    Int?
  status          String         @default("pending")
  audioPrompt     String?
  voiceProvider   String?
  voiceUrl        String?
  validatedByUser Boolean        @default(false)
  createdAt       DateTime       @default(now())
  episode         Episode        @relation(fields: [episodeId], references: [id], onDelete: Cascade)
}

model Asset {
  id        String   @id @default(cuid())
  seriesId  String
  type      String
  name      String
  url       String?
  prompt    String?
  reusable  Boolean  @default(true)
  createdAt DateTime @default(now())
  series    Series   @relation(fields: [seriesId], references: [id], onDelete: Cascade)
}
